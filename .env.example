PORT=3010
NODE_ENV=production
BASE_PATH=/claudenet

# Seed users (auto-created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=admin
USER_EMAIL=user@example.com
USER_NAME=user

# Or provide as JSON: SEED_USERS=[{"email":"a@example.com","display_name":"alice","role":"admin"}]

# Discord webhook for notifications (optional)
CLAUDENET_DISCORD_WEBHOOK=

# Deploy settings (used by deploy.sh)
DEPLOY_HOST=your-server.example.com
DEPLOY_USER=deploy
DEPLOY_KEY=~/.ssh/id_rsa
DEPLOY_PATH=/opt/claudenet
