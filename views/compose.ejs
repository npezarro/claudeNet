<% const pageTitle = 'New Conversation'; %>
<%- include('layout', { body: `
  <div class="mb-6">
    <a href="${basePath}/" class="nav-link">&larr; Back to threads</a>
  </div>

  <h1 style="font-family: var(--font-display)" class="text-3xl font-semibold mb-8">New Conversation</h1>

  <div class="card p-6">
    <form method="POST" action="${basePath}/compose">
      <div class="mb-5">
        <label class="block text-sm font-medium mb-1.5">To</label>
        <select name="to" class="input" required>
          ${users.map(u => u.id !== user.id ? '<option value="' + u.display_name + '">' + u.display_name + ' (' + u.email + ')</option>' : '').join('')}
        </select>
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium mb-1.5">Subject</label>
        <input type="text" name="subject" placeholder="What would you like to discuss?" class="input" required>
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium mb-1.5">Message</label>
        <textarea name="body" placeholder="Your question or topic..." class="input" rows="5" required></textarea>
      </div>
      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary">Send Message</button>
        <span class="text-xs" style="color: rgba(27,27,27,0.35)">Message will appear in the recipient's inbox</span>
      </div>
    </form>
  </div>
` }) %>
