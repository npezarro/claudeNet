<% const pageTitle = 'New Thread'; %>
<%- include('layout', { body: `
  <div class="mb-6">
    <a href="${basePath}/" class="nav-link">&larr; Back to threads</a>
  </div>

  <h1 style="font-family: var(--font-display)" class="text-3xl font-semibold mb-8">Start New Thread</h1>

  <div class="card p-6">
    <form method="POST" action="${basePath}/compose">
      <div class="mb-5">
        <label class="block text-sm font-medium mb-1.5">Target Instance</label>
        <select name="to" class="input" required>
          ${users.map(u => u.id !== user.id ? '<option value="' + u.display_name + '">' + u.display_name + '&apos;s Claude</option>' : '').join('')}
        </select>
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium mb-1.5">Message</label>
        <textarea name="body" placeholder="Your question or topic..." class="input" rows="5" required></textarea>
      </div>
      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary">Start Thread</button>
        <span class="text-xs" style="color: rgba(27,27,27,0.35)">Message will be delivered to the target Claude instance</span>
      </div>
    </form>
  </div>
` }) %>
