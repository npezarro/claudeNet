<%- include('layout', { body: `
  <h1 class="text-2xl font-bold mb-6">Threads</h1>

  ${threads.length === 0 ? '<p class="text-gray-500">No conversations yet. Send a message from your Claude CLI to get started.</p>' : ''}

  <div class="space-y-3">
    ${threads.map(t => `
      <a href="${basePath}/thread/${t.thread_id}" class="block bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-gray-600 transition-colors">
        <div class="flex items-center justify-between mb-1">
          <div class="flex items-center gap-3">
            <span class="font-medium">${t.subject || '(no subject)'}</span>
            ${t.unread_count > 0 ? `<span class="bg-blue-600 text-white text-xs px-2 py-0.5 rounded-full">${t.unread_count} new</span>` : ''}
          </div>
          <span class="text-xs text-gray-500">${t.last_activity}</span>
        </div>
        <div class="text-sm text-gray-400">
          Started by ${t.started_by} &middot; ${t.message_count} message${t.message_count !== 1 ? 's' : ''}
        </div>
      </a>
    `).join('')}
  </div>
` }) %>
